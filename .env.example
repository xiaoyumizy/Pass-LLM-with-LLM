# ── Question Generation ────────────────────────────────────────
# Set to your preferred LiteLLM model to enable auto question generation.
# Examples: deepseek/deepseek-chat, dashscope/qwen-plus, openai/gpt-4o-mini
# There is no default — leave empty to disable LLM generation.
EXAM_MEMORY_LLM_MODEL=

# ── Embedding Provider ─────────────────────────────────────────
# "local" (default) uses sentence-transformers with EXAM_MEMORY_EMBEDDING_MODEL.
# "api" uses an OpenAI-compatible embeddings endpoint.
EXAM_MEMORY_EMBEDDING_PROVIDER=local

# ── Local Embedding Model ──────────────────────────────────────
# Default: BAAI/bge-m3 (CPU-only, auto-downloaded on first use).
# Can be a HuggingFace model ID or a local directory path.
EXAM_MEMORY_EMBEDDING_MODEL=BAAI/bge-m3

# Set to 1 to block online model downloads (requires pre-cached model).
EXAM_MEMORY_EMBEDDING_LOCAL_FILES_ONLY=0

# Set to 1 to L2-normalize embeddings before indexing.
EXAM_MEMORY_EMBEDDING_NORMALIZE=1

# ── API Embedding Provider (when PROVIDER=api) ─────────────────
# OpenAI-compatible endpoint for embeddings.
EXAM_MEMORY_EMBEDDING_API_BASE=
EXAM_MEMORY_EMBEDDING_API_KEY=
EXAM_MEMORY_EMBEDDING_API_MODEL=

# ── Provider API Keys ──────────────────────────────────────────
# Set the key for your chosen LLM provider.
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# OPENAI_API_KEY=
# OPENAI_API_BASE=http://localhost:8000/v1
